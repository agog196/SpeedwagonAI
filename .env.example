SPEEDWAGON_DB_PATH=data/speedwagon.db
SPEEDWAGON_NOTES_DIR=notes
SPEEDWAGON_AUDIO_DIR=audio
SPEEDWAGON_TRANSCRIPTS_DIR=transcripts
SPEEDWAGON_STATE_PATH=data/recording.json
# Optional. Leave blank to auto-detect afrecord, rec, or ffmpeg.
SPEEDWAGON_RECORD_CMD=

WHISPER_CPP_BIN=/path/to/whisper-cli
WHISPER_CPP_MODEL=/path/to/ggml-base.en.bin

LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=

GMAIL_CREDENTIALS_PATH=data/google_credentials.json
GMAIL_TOKEN_PATH=data/google_token.json
