SPEEDWAGON_DB_PATH=data/speedwagon.db
SPEEDWAGON_NOTES_DIR=notes
SPEEDWAGON_AUDIO_DIR=audio
SPEEDWAGON_TRANSCRIPTS_DIR=transcripts
SPEEDWAGON_STATE_PATH=data/recording.json
SPEEDWAGON_APP_HOST=127.0.0.1
SPEEDWAGON_APP_PORT=8765
# Optional. Leave blank to auto-detect afrecord, rec, or ffmpeg.
SPEEDWAGON_RECORD_CMD=
# mic or blackhole. BlackHole needs a virtual device such as "BlackHole 2ch".
SPEEDWAGON_CAPTURE_PROFILE=mic
SPEEDWAGON_INPUT_DEVICE=

WHISPER_CPP_BIN=/path/to/whisper-cli
WHISPER_CPP_MODEL=/path/to/ggml-base.en.bin

LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=

# Optional cost/model routing overrides.
SPEEDWAGON_MODEL_CHEAP=gpt-4.1-mini
SPEEDWAGON_MODEL_STRONG=gpt-4.1
SPEEDWAGON_MODEL_COMMAND=
SPEEDWAGON_MODEL_VISION=
SPEEDWAGON_MODEL_WEB=
SPEEDWAGON_ENABLE_WEB_SEARCH=false

GMAIL_CREDENTIALS_PATH=data/google_credentials.json
GMAIL_TOKEN_PATH=data/google_token.json
